'use client'

import { useState } from 'react'
import type { StrandedSite } from '@/types/site'

interface SiteDetailsPanelProps {
  site: StrandedSite | null
  onClose: () => void
}

type Currency = 'USD' | 'CAD' | 'BTC' | 'EUR' | 'RMB'

const ASIC_MODELS = {
  's19_xp': { name: 'Antminer S19 XP', hashrate: 140, power: 3010, cost: 2500 },
  's19j_pro': { name: 'Antminer S19j Pro', hashrate: 104, power: 3068, cost: 1800 },
  's21': { name: 'Antminer S21', hashrate: 200, power: 3500, cost: 4000 },
  'm60s': { name: 'WhatsMiner M60S', hashrate: 170, power: 3400, cost: 3200 },
  'm50s': { name: 'WhatsMiner M50S', hashrate: 126, power: 3276, cost: 2200 },
}

const EXCHANGE_RATES: Record<Currency, number> = {
  USD: 1,
  CAD: 1.35,
  EUR: 0.92,
  RMB: 7.25,
  BTC: 0.000011,
}

const CURRENCY_SYMBOLS: Record<Currency, string> = {
  USD: '$',
  CAD: 'C$',
  EUR: '€',
  RMB: '¥',
  BTC: '₿',
}

export default function SiteDetailsPanel({ site, onClose }: SiteDetailsPanelProps) {
  const [currency, setCurrency] = useState<Currency>('BTC')
  const [advancedMode, setAdvancedMode] = useState(false)
  const [asicModel, setAsicModel] = useState<keyof typeof ASIC_MODELS>('s19_xp')
  const [btcPrice, setBtcPrice] = useState(91000)
  const [difficulty, setDifficulty] = useState(110)

  if (!site) return null

  const p = site.properties
  const emissionKgDay = p.emission_rate_kg_day || 0
  const asic = ASIC_MODELS[asicModel]

  const methaneEnergyMjPerKg = 50
  const generatorEfficiency = 0.35
  const powerKw = (emissionKgDay * methaneEnergyMjPerKg * generatorEfficiency) / 24
  const minersSupported = Math.floor((powerKw * 1000) / asic.power)

  const totalHashrate = minersSupported * asic.hashrate
  const btcPerDay = (totalHashrate * 86400 * 6.25) / (difficulty * 1e12 * Math.pow(2, 32))
  const revenueUsdPerDay = btcPerDay * btcPrice
  const profitUsdPerDay = revenueUsdPerDay * 0.99

  const convert = (usd: number): string => {
    const rate = EXCHANGE_RATES[currency]
    const val = usd * rate
    if (currency === 'BTC') return val.toFixed(8)
    return val.toLocaleString(undefined, { maximumFractionDigits: 2 })
  }
return
(
    <div className="absolute top-20 right-4 z-10 bg-[#1e293b]/95 backdrop-blur border border-[#5BC0BE]/30 rounded-xl p-6 shadow-lg max-w-md max-h-[calc(100vh-120px)] overflow-y-auto">
      <div className="flex items-start justify-between mb-4">
        <h2 className="text-xl font-bold text-white">{p.name}</h2>
        <button onClick={onClose} className="text-gray-400 hover:text-white">✕</button>
      </div>

      <div className="space-y-2 text-sm mb-4 pb-4 border-b border-[#5BC0BE]/20">
        <div className="flex justify-between">
          <span className="text-gray-400">Location</span>
          <span className="text-white">{p.city || p.region || 'Unknown'}</span>
        </div>
        <div className="flex justify-between">
          <span className="text-gray-400">CH₄ Emissions</span>
          <span className="text-[#FF8C00] font-semibold">{emissionKgDay.toLocaleString()} kg/day</span>
        </div>
        <div className="flex justify-between">
          <span className="text-gray-400">Available Power</span>
          <span className="text-[#5BC0BE]">{powerKw.toFixed(1)} kW</span>
        </div>
      </div>

      <div className="flex gap-1 mb-4">
        {(['BTC', 'USD', 'CAD', 'EUR', 'RMB'] as Currency[]).map(c => (
          <button
            key={c}
            onClick={() => setCurrency(c)}
            className={`flex-1 px-2 py-1 rounded text-xs font-semibold ${currency === c ? 'bg-[#FF8C00] text-white' : 'bg-[#0f172a] text-gray-400'}`}
          >
            {c}
          </button>
        ))}
      </div>

      <div className="mb-4">
        <label className="block text-xs text-gray-400 mb-1">Mining Hardware</label>
        <select
          value={asicModel}
          onChange={(e) => setAsicModel(e.target.value as keyof typeof ASIC_MODELS)}
          className="w-full bg-[#0f172a] border border-[#5BC0BE]/30 rounded-lg px-3 py-2 text-white text-sm"
        >
          {Object.entries(ASIC_MODELS).map(([key, val]) => (
            <option key={key} value={key}>{val.name} — {val.hashrate} TH/s @ {val.power}W</option>
          ))}
        </select>
      </div>

      <div className="mb-4">
        <button onClick={() => setAdvancedMode(!advancedMode)} className="text-xs text-[#5BC0BE] hover:text-[#FF8C00]">
          {advancedMode ? '▼ Hide Advanced' : '▶️ Show Advanced'}
        </button>
      </div>

      {advancedMode && (
        <div className="space-y-3 mb-4 pb-4 border-b border-[#5BC0BE]/20">
          <div>
            <label className="block text-xs text-gray-400 mb-1">BTC Price (USD)</label>
            <input type="number" value={btcPrice} onChange={(e) => setBtcPrice(Number(e.target.value))} className="w-full bg-[#0f172a] border border-[#5BC0BE]/30 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
          <div>
            <label className="block text-xs text-gray-400 mb-1">Network Difficulty (T)</label>
            <input type="number" value={difficulty} onChange={(e) => setDifficulty(Number(e.target.value))} className="w-full bg-[#0f172a] border border-[#5BC0BE]/30 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
        </div>
      )}

      <div className="space-y-3 bg-[#0f172a] rounded-lg p-4">
        <h3 className="text-sm font-semibold text-[#5BC0BE]">Mining Economics ROI CALC v2</h3>
        <div className="flex justify-between text-sm">
          <span className="text-gray-400">Miners Supported</span>
          <span className="text-white font-semibold">{minersSupported}</span>
        </div>
        <div className="flex justify-between text-sm">
          <span className="text-gray-400">Total Hashrate</span>
          <span className="text-white">{totalHashrate.toFixed(1)} TH/s</span>
        </div>
        <div className="flex justify-between text-sm">
          <span className="text-gray-400">Daily Revenue</span>
          <span className="text-[#5BC0BE]">{CURRENCY_SYMBOLS[currency]}{convert(revenueUsdPerDay)}</span>
        </div>
        <div className="flex
justify-between text-sm">
          <span className="text-gray-400">Daily Profit</span>
          <span className="text-[#FF8C00] font-bold">{CURRENCY_SYMBOLS[currency]}{convert(profitUsdPerDay)}</span>
        </div>
        <div className="flex justify-between text-sm">
          <span className="text-gray-400">Annual Profit</span>
          <span className="text-[#FF8C00] font-bold">{CURRENCY_SYMBOLS[currency]}{convert(profitUsdPerDay * 365)}</span>
        </div>
      </div>
    </div>
  )
}
